# SENIOR ENGINEER CONFIGURATION
# Optimized for cPanel/Apache React Deployments

# 1. Stability & Standards
Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 2. Domain Standardization (Force HTTPS + WWW)
  # This prevents "Connection Reset" during mixed-protocol loading
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^(.*)$ https://www.isisecurity.in/$1 [L,R=301]

  # 3. SPA Routing (React Router)
  # If it's not a real file/folder, serve index.html
  RewriteRule ^index\.html$ - [L]
  
  # Optimization: Don't rewrite known assets (Fail fast if missing)
  RewriteCond %{REQUEST_URI} !\.(js|css|svg|png|jpg|jpeg|gif|ico|woff|woff2|ttf|eot|map|json)$ [NC]
  
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # 4. Critical Cache Control (Fixes "First Load" Issues)
  # Force browsers to NEVER cache index.html. They must ask the server for the latest version.
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Cache Assets aggressively (since filenames change with every build)
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$">
    Header set Cache-Control "max-age=31536000, public"
  </FilesMatch>
  
  # 5. Security (Safe Mode)
  # Minimal headers to avoid triggering WAF/ModSecurity false positives
  Header set Access-Control-Allow-Origin "https://www.isisecurity.in"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Content-Security-Policy "frame-ancestors 'self';"
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
  AddType image/svg+xml .svg
</IfModule>
